@page "/orders/new"
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Novo Pedido — Good Hamburger</PageTitle>

<div class="page-header">
    <h1>➕ Novo Pedido</h1>
    <p>Selecione os itens e confira o total com desconto</p>
</div>

@if (_loadingMenu)
{
    <div class="loading-container">
        <div class="spinner"></div>
        <span>A carregar cardápio…</span>
    </div>
}
else
{
    <div class="form-card">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-error">⚠️ @_error</div>
        }

        <!-- Sandwiches -->
        <div class="form-section-title">🍔 Escolha um sanduíche</div>
        <div class="item-selector">
            @foreach (var item in _sandwiches)
            {
                var capturedItem = item;
                var isSelected = _selectedCodes.Contains(capturedItem.Code);
                <label class="item-toggle @(isSelected ? "selected" : "")">
                    <input type="checkbox"
                           checked="@isSelected"
                           @onchange="() => ToggleSandwich(capturedItem.Code)" />
                    <span class="menu-item-emoji" style="font-size:22px">🍔</span>
                    <span class="toggle-info">
                        <span class="toggle-name">@capturedItem.Name</span>
                        <span class="toggle-type">Sanduíche</span>
                    </span>
                    <span class="toggle-price">R$ @capturedItem.Price.ToString("N2")</span>
                </label>
            }
        </div>

        <!-- Sides -->
        <div class="form-section-title">🍟 Escolha acompanhamentos (opcional)</div>
        <div class="item-selector">
            @foreach (var item in _sides)
            {
                var capturedItem = item;
                var isSelected = _selectedCodes.Contains(capturedItem.Code);
                var emoji = capturedItem.Name.Contains("Batata") ? "🍟" : "🥤";
                <label class="item-toggle @(isSelected ? "selected" : "")">
                    <input type="checkbox"
                           checked="@isSelected"
                           @onchange="() => ToggleSide(capturedItem.Code)" />
                    <span class="menu-item-emoji" style="font-size:22px">@emoji</span>
                    <span class="toggle-info">
                        <span class="toggle-name">@capturedItem.Name</span>
                        <span class="toggle-type">Acompanhamento</span>
                    </span>
                    <span class="toggle-price">R$ @capturedItem.Price.ToString("N2")</span>
                </label>
            }
        </div>

        
        @if (_selectedCodes.Count > 0)
        {
            <div class="order-preview">
                <div class="preview-title">📊 Resumo do Pedido</div>
                @foreach (var code in _selectedCodes)
                {
                    var item = _allMenu.First(m => m.Code == code);
                    <div class="preview-row">
                        <span>@item.Name</span>
                        <span>R$ @item.Price.ToString("N2")</span>
                    </div>
                }
                <div class="preview-row" style="border-top:1px solid var(--border);margin-top:8px;padding-top:8px;color:var(--text-secondary)">
                    <span>Subtotal</span>
                    <span>R$ @_subtotal.ToString("N2")</span>
                </div>
                @if (_discountPct > 0)
                {
                    <div class="preview-row discount">
                        <span>Desconto (@_discountPct%)</span>
                        <span>-R$ @_discountAmt.ToString("N2")</span>
                    </div>
                }
                <div class="preview-row total">
                    <span>Total</span>
                    <span>R$ @_total.ToString("N2")</span>
                </div>
            </div>
        }

        <div style="display:flex;gap:12px">
            <a href="orders" class="btn btn-secondary">← Cancelar</a>
            <button class="btn btn-primary" @onclick="Submit" disabled="@(_saving || _selectedCodes.Count == 0)">
                @(_saving ? "A salvar…" : "✅ Confirmar Pedido")
            </button>
        </div>
    </div>
}

@code {
    private List<MenuItemModel> _allMenu = [];
    private List<MenuItemModel> _sandwiches = [];
    private List<MenuItemModel> _sides = [];
    private HashSet<int> _selectedCodes = [];
    private bool _loadingMenu = true;
    private bool _saving = false;
    private string? _error;

    
    private decimal _subtotal    => _selectedCodes.Sum(c => _allMenu.FirstOrDefault(m => m.Code == c)?.Price ?? 0m);
    private bool _hasSandwich    => _selectedCodes.Any(c => _sandwiches.Any(s => s.Code == c));
    private bool _hasFries       => _selectedCodes.Any(c => _sides.Any(s => s.Code == c && s.Name.Contains("Batata")));
    private bool _hasSoda        => _selectedCodes.Any(c => _sides.Any(s => s.Code == c && s.Name.Contains("Refrigerante")));
    private decimal _discountPct => (_hasSandwich, _hasFries, _hasSoda) switch {
        (true, true, true)  => 20m,
        (true, false, true) => 15m,
        (true, true, false) => 10m,
        _ => 0m
    };
    private decimal _discountAmt => Math.Round(_subtotal * _discountPct / 100m, 2);
    private decimal _total       => Math.Round(_subtotal - _discountAmt, 2);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _allMenu     = await Api.GetMenuAsync() ?? [];
            _sandwiches  = _allMenu.Where(m => m.Type == "Sandwich").ToList();
            _sides       = _allMenu.Where(m => m.Type == "Side").ToList();
        }
        catch
        {
            _error = "Não foi possível carregar o cardápio. Verifique se a API está em execução.";
        }
        finally
        {
            _loadingMenu = false;
        }
    }

    private void ToggleSandwich(int code)
    {

        var alreadySelected = _selectedCodes.Contains(code);

        foreach (var s in _sandwiches) _selectedCodes.Remove(s.Code);

        if (!alreadySelected)
            _selectedCodes.Add(code);
        _error = null;
    }

    private void ToggleSide(int code)
    {
        if (_selectedCodes.Contains(code))
            _selectedCodes.Remove(code);
        else
            _selectedCodes.Add(code);
        _error = null;
    }

    private async Task Submit()
    {
        _error = null;
        _saving = true;
        var request = new CreateOrderRequest { Items = [.. _selectedCodes] };
        var result = await Api.CreateOrderAsync(request);

        if (result is not null)
            Nav.NavigateTo("orders");
        else
            _error = "Não foi possível criar o pedido. Verifique os itens selecionados.";

        _saving = false;
    }
}
